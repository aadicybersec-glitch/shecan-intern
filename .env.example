# =========================================================================
# SHE CAN FOUNDATION - ENVIRONMENT CONFIGURATION BLUEPRINT
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND ENGINE CONFIGURATIONS (server/.env)
# -------------------------------------------------------------------------

# The port where the Express REST API server will run locally
PORT=5000

# The operational environment mode (development | production)
NODE_ENV=development

# MongoDB Atlas cluster connection URI
# LEAVE EMPTY to dynamically activate Recruiter Local JSON File Fallback Mode!
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shecan?retryWrites=true&w=majority

# Private key used for signing JWT administrative authorization tokens
# LEAVE EMPTY to automatically utilize the built-in system backup key!
JWT_SECRET=your_ultra_secure_custom_jwt_secret_signature_key_2026

# -------------------------------------------------------------------------
# FRONTEND ENGINE CONFIGURATIONS (.env)
# -------------------------------------------------------------------------

# The URL of the operational REST API server
# Vite requires environment keys to be prefixed with VITE_ to be exposed to client-side code
VITE_API_URL=http://localhost:5000/api
